# Copy to .env for local development — NEVER commit .env
# See SECURITY.md for rotation policy and incident checklist.

# ── Auth (REQUIRED) ───────────────────────────────────────────────────────────
# Signs session JWTs for email/password and guest flows. Use 48+ random bytes.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_JWT_SECRET=
# Deprecated alias — code falls back to this if AUTH_JWT_SECRET is unset; prefer AUTH_JWT_SECRET only.
# LEXICOIL_JWT_SECRET=

# ── Google Gemini (content batch generation — de/B1 bank) ───────────────────
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Default: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash
# Alternativa más cupo diario gratis: gemini-2.5-flash-lite (~15 RPM / ~1000 RPD)
# GEMINI_RPM=8          # peticiones/min (free tier 2.5-flash ≈10; deja margen)
# GEMINI_RPD=240        # peticiones/día (free tier 2.5-flash ≈250; deja margen)
# Prompt compacto por defecto en API; GEMINI_FULL_PROMPT=1 usa el prompt largo
# GEMINI_MAX_OUTPUT_TOKENS=8192

# ── Offline batch generation provider (scripts/ — NOT production claude-chat) ─
# GEN_PROVIDER=claude          # claude | gemini (default: claude)
# CLAUDE_GEN_MODEL=claude-haiku-4-5   # higher quality: claude-sonnet-4-6
# CLAUDE_MAX_OUTPUT_TOKENS=8000       # floor; lesen T2/T3 auto-bump to 16384
# GEN_MAX_OUTPUT_TOKENS=16384         # optional hard cap for all jobs
# CLAUDE_BUDGET_USD=2.30              # hard spend cap for offline Claude generation

# ── Anthropic (REQUIRED for AI exam generation) ───────────────────────────────
# https://console.anthropic.com/ → API keys
ANTHROPIC_API_KEY=
# Default model for vocab/chat (non-exam)
CLAUDE_MODEL=claude-sonnet-4-5
# Exam generation model (chunked exams)
CLAUDE_EXAM_MODEL=claude-sonnet-4-20250514
# Optional: Haiku model for server-side answer-key verification
# CLAUDE_VERIFY_MODEL=claude-haiku-4-5
# Optional: enable AI answer-key spot-check (1 = on)
# EXAM_ANSWER_KEY_VERIFY=0
# EXAM_ANSWER_KEY_MISMATCH_THRESHOLD=0.35

# ── Supabase (REQUIRED for auth + user data) ──────────────────────────────────
# Project Settings → API → URL and anon public key
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role secret — ONLY for Netlify Functions (server-side). NEVER expose to client.
# Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (REQUIRED for payments) ────────────────────────────────────────────
# Dashboard → Developers → API keys (secret key)
STRIPE_SECRET_KEY=
# Dashboard → Developers → Webhooks → signing secret for checkout.session.completed
STRIPE_WEBHOOK_SECRET=
# Publishable key (client-safe; optional in .env if only used in Netlify UI)
# STRIPE_PUBLISHABLE_KEY=

# ── Resend (optional — Pro welcome email after payment) ───────────────────────
# RESEND_API_KEY=
# RESEND_FROM=LexiCoil <noreply@lexicoil.com>

# ── Admin (optional — manual Pro activation via admin-activate-pro) ───────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# ADMIN_SECRET=

# ── Site / CORS ───────────────────────────────────────────────────────────────
LEXICOIL_SITE_URL=https://www.lexicoil.com
LEXICOIL_ALLOWED_ORIGINS=https://www.lexicoil.com,https://lexicoil.com
# Legacy site URL fallback in code — prefer LEXICOIL_SITE_URL
# LEXILOOP_SITE_URL=https://www.lexicoil.com

# ── Dev / preview only ────────────────────────────────────────────────────────
# Allow *.netlify.app origins when true (do not enable in production)
# ALLOW_NETLIFY_PREVIEWS=true

# ── TTS (optional — listening audio cache) ────────────────────────────────────
# none | stub | polly | google | elevenlabs
# TTS_PROVIDER=none

# ── E2E / timing tests (optional) ─────────────────────────────────────────────
# EXAM_CHUNK_LIMIT_MS=26000
